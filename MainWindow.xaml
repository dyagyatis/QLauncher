<Window x:Class="MinecraftLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="QLauncher" Height="700" Width="1100"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        FontFamily="Inter">

    <Border x:Name="OuterBorder" CornerRadius="14" ClipToBounds="True" BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="3">
        <Grid>
            <tb:TaskbarIcon x:Name="LauncherTrayIcon" IconSource="/logo.png" ToolTipText="QLauncher работает" Visibility="Collapsed" TrayMouseDoubleClick="LauncherTrayIcon_TrayMouseDoubleClick">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="1">
                        <MenuItem Header="Развернуть лаунчер" Click="TrayRestore_Click" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <Separator Background="{DynamicResource WindowBorderBrush}"/>
                        <MenuItem Header="Закрыть QLauncher" Click="TrayExit_Click" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>

            <Border x:Name="BackgroundBorder" CornerRadius="0,0,15,15" ClipToBounds="True" Margin="0,40,0,0">
                <Border.Background>
                    <ImageBrush ImageSource="/bg.png" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>

            <Grid x:Name="ContentGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border x:Name="TitleBorder" Grid.Row="0" MouseDown="Window_MouseDown" Background="{DynamicResource TitleBarBrush}" CornerRadius="10,10,0,0">
                    <Grid Margin="10,0,0,0">
                        <Image Source="/logo.png" Width="24" Height="24" HorizontalAlignment="Left" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" Margin="-8,0,0,0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="ThemeToggleBtn" Content="&#xE706;" Style="{DynamicResource CaptionButtonStyle}" Click="ThemeToggleBtn_Click" ToolTip="Сменить тему"/>
                            <Button Content="&#xE74C;" Style="{DynamicResource CaptionButtonStyle}" Click="ModsButton_Click" ToolTip="Скачать моды"/>
                            <Button Content="&#xE713;" Style="{DynamicResource CaptionButtonStyle}" Click="SettingsButton_Click" ToolTip="Настройки"/>
                            <Button Content="&#xE921;" Style="{DynamicResource CaptionButtonStyle}" Click="MinimizeButton_Click"/>
                            <Button Content="&#xE922;" Style="{DynamicResource CaptionButtonStyle}" Click="MaximizeButton_Click"/>
                            <Button x:Name="CloseBtn" Content="&#xE8BB;" Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid x:Name="HomeView" Grid.Row="1" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="85"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="20,15,20,13">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="241"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" CornerRadius="20" Margin="0,0,13,0" Background="{DynamicResource PanelBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Новости" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="24" HorizontalAlignment="Center" Margin="0,15,0,15" FontFamily="Inter"/>
                                <Border Grid.Row="0" BorderBrush="{DynamicResource HoverOverlayBrush}" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

                                <ScrollViewer Grid.Row="1" Margin="15,10,15,15" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="NewsItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource HoverOverlayBrush}" CornerRadius="10" Margin="0,0,0,15" Padding="15">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Date}" Foreground="{DynamicResource AccentBrush}" FontSize="12" FontFamily="Inter" FontWeight="Bold" Margin="0,0,0,8"/>
                                                        <Border CornerRadius="6" Margin="0,0,0,10" Visibility="{Binding ImageVisibility}" ClipToBounds="True">
                                                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" MaxHeight="180" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Text}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="14" FontFamily="Inter" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Background="{DynamicResource PanelBrush}" CornerRadius="20" ClipToBounds="True">
                            <Grid>
                                <TextBlock Text="Ваши сервера" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="Inter" Height="30" TextAlignment="Center" Margin="0,16,0,0"/>
                                <Border BorderBrush="{DynamicResource HoverOverlayBrush}" BorderThickness="0,1,0,0" VerticalAlignment="Top" Margin="0,58,0,0"/>

                                <ScrollViewer Margin="0,51,0,0" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ServersItemsControl" Margin="20,15,20,20">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,15">
                                                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding OnlineText}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" HorizontalAlignment="Right"/>

                                                    <Border Height="6" Background="{DynamicResource HoverOverlayBrush}" CornerRadius="3" Margin="0,18,0,0" VerticalAlignment="Top">
                                                        <Border Width="{Binding ProgressWidth}" HorizontalAlignment="Left" Background="{DynamicResource AccentBrush}" CornerRadius="3"/>
                                                    </Border>

                                                    <TextBlock Text="{Binding Version}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="0,28,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border x:Name="FooterBorder" Grid.Row="1" Background="{DynamicResource FooterBrush}" CornerRadius="0,0,12,12">
                        <Grid Margin="20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="NicknameComboBox" Grid.Column="0" Height="45" Margin="0,0,10,0" Style="{StaticResource CustomComboBoxStyle}" Background="{DynamicResource InputNicknameBgBrush}" Padding="10,0,0,0" VerticalContentAlignment="Center" SelectionChanged="NicknameComboBox_SelectionChanged" TextSearch.TextPath="Nickname">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Grid x:Name="MsLogo" Width="12" Height="12" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition/>
                                                    <RowDefinition/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>
                                                <Rectangle Fill="#F25022" Margin="0,0,1,1"/>
                                                <Rectangle Grid.Column="1" Fill="#7FBA00" Margin="1,0,0,1"/>
                                                <Rectangle Grid.Row="1" Fill="#00A4EF" Margin="0,1,1,0"/>
                                                <Rectangle Grid.Row="1" Grid.Column="1" Fill="#FFB900" Margin="1,1,0,0"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Nickname}" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>

                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding AccessToken}" Value="offline">
                                                <Setter TargetName="MsLogo" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <ComboBox x:Name="VersionComboBox" SelectionChanged="VersionComboBox_SelectionChanged" Grid.Column="1" Height="45" Margin="0,0,10,0" Style="{StaticResource CustomComboBoxStyle}" Padding="15,0,0,0" VerticalContentAlignment="Center"/>

                            <Button Grid.Column="2" Content="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="16" Height="45" Margin="0,0,5,0" Style="{StaticResource DarkButtonStyle}" ToolTip="Создать сборку" Click="OpenModpackOverlay_Click"/>

                            <Button Grid.Column="3" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="16" Height="45" Margin="0,0,5,0" ToolTip="Удалить выбранную сборку" Click="DeleteModpackBtn_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DarkButtonStyle}">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E81123"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Grid.Column="4" Content="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Height="45" Margin="0,0,15,0" Style="{StaticResource DarkButtonStyle}" ToolTip="Создать ярлык на рабочий стол" Click="OpenShortcutOverlay_Click"/>

                            <Grid Grid.Column="5" Height="46" Margin="0,0,20,0">
                                <Border Background="{DynamicResource HoverOverlayBrush}" CornerRadius="23"/>
                                <Border x:Name="ProgressFillBorder" HorizontalAlignment="Left" Width="0" Background="{DynamicResource AccentBrush}" CornerRadius="23"/>
                                <TextBlock x:Name="ProgressTextBlock" Text="Готов к запуску" Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontFamily="Inter"/>
                            </Grid>

                            <Button x:Name="PlayButton" Grid.Column="6" Content="Играть" Height="45" Style="{StaticResource PlayButtonStyle}" Click="PlayButton_Click" FontFamily="Inter" FontSize="22"/>
                        </Grid>
                    </Border>
                </Grid>

                <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden" Visibility="Collapsed" Background="Transparent">
                    <Frame.RenderTransform>
                        <TranslateTransform x:Name="MainFrameTransform" X="0"/>
                    </Frame.RenderTransform>
                </Frame>

                <Grid x:Name="ModpackOverlay" Grid.Row="1" Visibility="Collapsed" Opacity="0">
                    <Border Background="#AA000000" MouseDown="CloseModpackOverlay_Click"/>
                    <Border Width="480" Height="520" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="16" Background="{DynamicResource ModpackOverlayBgBrush}" BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" Opacity="0.5" BlurRadius="20"/>
                        </Border.Effect>
                        <Grid Margin="30">
                            <TextBlock Text="Создать сборку" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="Inter"/>

                            <StackPanel Margin="0,50,0,0">
                                <TextBlock Text="Название сборки" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,5" FontFamily="Inter"/>
                                <TextBox x:Name="ModpackNameBox" Text="Моя крутая сборка" Height="42" Style="{StaticResource CustomTextBoxStyle}" Margin="0,0,0,15" Padding="15,0"/>

                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Версия игры" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,5" FontFamily="Inter"/>
                                        <ComboBox x:Name="ModpackVersionBox" Height="42" Style="{StaticResource CustomComboBoxStyle}" Padding="15,0,0,0" VerticalContentAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="Провайдер" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,5" FontFamily="Inter"/>
                                        <ComboBox x:Name="ModProviderBox" Height="42" Style="{StaticResource CustomComboBoxStyle}" Padding="15,0,0,0" VerticalContentAlignment="Center">
                                            <ComboBoxItem Content="Modrinth" IsSelected="True"/>
                                            <ComboBoxItem Content="CurseForge"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Загрузчик модов" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,5" FontFamily="Inter"/>
                                <ComboBox x:Name="ModLoaderBox" Height="42" Style="{StaticResource CustomComboBoxStyle}" Margin="0,0,0,15" Padding="15,0,0,0" VerticalContentAlignment="Center" SelectionChanged="ModLoaderBox_SelectionChanged">
                                    <ComboBoxItem Content="Vanilla" IsSelected="True"/>
                                    <ComboBoxItem Content="Fabric"/>
                                    <ComboBoxItem Content="Forge"/>
                                    <ComboBoxItem Content="NeoForge"/>
                                    <ComboBoxItem Content="Quilt"/>
                                </ComboBox>

                                <StackPanel x:Name="FabricOptionsPanel" Visibility="Collapsed">
                                    <TextBlock Text="Автоматически установить:" Foreground="{DynamicResource AccentBrush}" FontSize="12" Margin="0,0,0,5" FontWeight="Bold" FontFamily="Inter"/>
                                    <CheckBox x:Name="InstallSodiumCheck" Content="Sodium (Глобальная оптимизация FPS)" Style="{StaticResource CustomCheckBox}" IsChecked="True"/>
                                    <CheckBox x:Name="InstallIrisCheck" Content="Iris (Поддержка шейдеров)" Style="{StaticResource CustomCheckBox}" IsChecked="True"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                <Button Content="Отмена" Width="140" Height="42" Style="{StaticResource DarkButtonStyle}" Margin="0,0,10,0" Click="CloseModpackOverlay_Click" FontFamily="Inter"/>
                                <Button Content="Создать" Width="140" Height="42" Style="{StaticResource PlayButtonStyle}" Click="CreateModpackBtn_Click" FontFamily="Inter"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border x:Name="ActionOverlay" Background="#CC0F111A" Visibility="Collapsed" Opacity="0" Panel.ZIndex="999">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontSize="40" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="SpinnerTransform" Angle="0"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SpinnerTransform" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    <TextBlock x:Name="ActionOverlayText" Text="Обработка..." Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>

            <Grid x:Name="ShortcutOverlay" Visibility="Collapsed" Opacity="0" Panel.ZIndex="900">
                <Border Background="#AA000000" MouseDown="CloseShortcutOverlay_Click"/>
                <Border Width="400" Height="350" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="16" Background="{DynamicResource ModpackOverlayBgBrush}" BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" Opacity="0.5" BlurRadius="20"/>
                    </Border.Effect>
                    <Grid Margin="30">
                        <TextBlock Text="Ярлык быстрого входа" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="Inter"/>

                        <StackPanel Margin="0,50,0,0">
                            <TextBlock Text="Выберите сборку/версию" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,5" FontFamily="Inter"/>
                            <ComboBox x:Name="ShortcutVersionBox" Height="42" Style="{StaticResource CustomComboBoxStyle}" Margin="0,0,0,15" Padding="15,0,0,0" VerticalContentAlignment="Center"/>

                            <TextBlock Text="IP-адрес сервера" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,5" FontFamily="Inter"/>
                            <TextBox x:Name="ShortcutIpBox" Text="mc.hypixel.net" Height="42" Style="{StaticResource CustomTextBoxStyle}" Margin="0,0,0,15" Padding="15,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                            <Button Content="Отмена" Width="110" Height="42" Style="{StaticResource DarkButtonStyle}" Margin="0,0,10,0" Click="CloseShortcutOverlay_Click" FontFamily="Inter"/>
                            <Button Content="Создать" Width="140" Height="42" Style="{StaticResource PlayButtonStyle}" Click="CreateShortcutBtn_Click" FontFamily="Inter"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>