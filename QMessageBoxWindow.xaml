<Window x:Class="MinecraftLauncher.QMessageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Уведомление" Width="400" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Topmost="True"
        FontFamily="Inter">

    <Border Background="#1A1C28" CornerRadius="12" Margin="20">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="TopAccent" Height="4" VerticalAlignment="Top" Background="#3B85E6" CornerRadius="12,12,0,0"/>

            <TextBlock x:Name="TitleText" Grid.Row="0" Text="Заголовок" Foreground="White" FontSize="16" FontWeight="Bold" Margin="20,15,20,10"/>

            <TextBlock x:Name="MessageText" Grid.Row="1" Text="Текст сообщения..." Foreground="#D1D5DB" FontSize="14" Margin="20,0,20,20" TextWrapping="Wrap"/>

            <Border Grid.Row="2" Background="#232634" CornerRadius="0,0,12,12" Padding="15">
                <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>