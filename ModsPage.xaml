<Page x:Class="MinecraftLauncher.ModsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Загрузка модов" FontFamily="Inter">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="40" Height="40" Style="{StaticResource DarkButtonStyle}" Click="BackButton_Click" ToolTip="Назад" Margin="0,0,15,0"/>

            <TextBox x:Name="SearchBox" Grid.Column="1" Style="{StaticResource CustomTextBoxStyle}" Height="40" Margin="0,0,10,0" KeyDown="SearchBox_KeyDown"/>

            <ComboBox x:Name="ProviderBox" Grid.Column="2" Width="150" Height="40" Style="{StaticResource CustomComboBoxStyle}" Margin="0,0,10,0" Padding="15,0,0,0" VerticalContentAlignment="Center">
                <ComboBoxItem Content="Modrinth" IsSelected="True"/>
                <ComboBoxItem Content="CurseForge"/>
            </ComboBox>

            <Button Grid.Column="3" Content="Искать" Width="100" Height="40" Style="{StaticResource PlayButtonStyle}" Click="SearchButton_Click"/>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" CornerRadius="15" Padding="15">
            <Grid>
                <TextBlock x:Name="LoadingText" Text="Введите название мода..." Foreground="{DynamicResource SecondaryTextBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ModsListControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource HoverOverlayBrush}" CornerRadius="10" Margin="0,0,0,10" Padding="15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="64"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>

                                        <Image Grid.Column="0" Source="{Binding IconUrl}" Width="64" Height="64" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Clip>
                                                <RectangleGeometry Rect="0,0,64,64" RadiusX="8" RadiusY="8"/>
                                            </Image.Clip>
                                        </Image>

                                        <StackPanel Grid.Column="1" Margin="15,0,10,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="16" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Author}" Foreground="{DynamicResource AccentBrush}" FontSize="12" Margin="0,2,0,5"/>
                                            <TextBlock Text="{Binding Description}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" TextWrapping="Wrap" MaxHeight="32" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Downloads}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" HorizontalAlignment="Right" Margin="0,0,0,5"/>
                                            <Button Content="Установить" Height="35" Style="{StaticResource PlayButtonStyle}" Tag="{Binding Slug}" Click="InstallMod_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>