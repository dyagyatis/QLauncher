<Window x:Class="MinecraftLauncher.SplashScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запуск QLauncher" Height="350" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        FontFamily="Inter" Opacity="0" Loaded="Window_Loaded">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="#1A1C28" CornerRadius="20" BorderBrush="#FF353535" BorderThickness="1" Margin="20">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="25" ShadowDepth="5" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Border CornerRadius="20" ClipToBounds="True" Opacity="0.1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3B85E6" Offset="0.0"/>
                        <GradientStop Color="Transparent" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="/logo.png" Width="96" Height="96" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,0,20"/>

                <TextBlock Text="QLauncher" Foreground="White" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Версия 1.0.0" Foreground="#9EA5B5" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <TextBlock x:Name="StatusText" Text="Запуск..." Foreground="#EBEBEB" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <Border Width="300" Height="6" Background="#282828" CornerRadius="3">
                    <Border x:Name="ProgressBarFill" Width="0" HorizontalAlignment="Left" Background="#3B85E6" CornerRadius="3"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>