<Page x:Class="MinecraftLauncher.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Настройки" FontFamily="Inter">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Button HorizontalAlignment="Left" Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="40" Height="40" Style="{StaticResource DarkButtonStyle}" Click="BackButton_Click" ToolTip="Назад"/>
            <TextBlock Text="Настройки" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" CornerRadius="15" Padding="25">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="ОСНОВНЫЕ" Foreground="{DynamicResource AccentBrush}" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

                    <CheckBox x:Name="CloseOnLaunchCheck" Content="Закрывать лаунчер при запуске игры" Style="{StaticResource CustomCheckBox}"/>
                    <CheckBox x:Name="DiscordRpcCheck" Content="Показывать статус в Discord (RPC)" Style="{StaticResource CustomCheckBox}"/>
                    <CheckBox x:Name="HideServerIpCheck" Content="Скрывать IP серверов в Discord" Style="{StaticResource CustomCheckBox}"/>
                    <CheckBox x:Name="AutoAddServersCheck" Content="Автоматически добавлять сервера SCRAFT" Style="{StaticResource CustomCheckBox}"/>

                    <Border Height="1" Background="{DynamicResource HoverOverlayBrush}" Margin="0,20"/>

                    <TextBlock Text="JAVA И ПАМЯТЬ" Foreground="{DynamicResource AccentBrush}" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Text="Выделение оперативной памяти (МБ)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="RamSlider" Minimum="1024" Maximum="16384" TickFrequency="1024" IsSnapToTickEnabled="True" ValueChanged="RamSlider_ValueChanged" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <TextBox x:Name="RamTextBox" Grid.Column="1" Text="4096" Style="{StaticResource CustomTextBoxStyle}" Height="35" TextAlignment="Center" Padding="0" IsReadOnly="True" FontSize="16"/>
                    </Grid>

                    <TextBlock Text="Свой путь к Java (оставьте пустым для авто-скачивания)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="JavaPathBox" Style="{StaticResource CustomTextBoxStyle}" Height="40" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" Content="Обзор..." Width="100" Height="40" Style="{StaticResource DarkButtonStyle}" Click="BrowseJava_Click" FontSize="16"/>
                    </Grid>

                    <Border Height="1" Background="{DynamicResource HoverOverlayBrush}" Margin="0,20"/>

                    <TextBlock Text="ВАШИ АККАУНТЫ" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13" Margin="0,0,0,5"/>
                    <Border Background="{DynamicResource HoverOverlayBrush}" CornerRadius="10" Margin="0,0,0,15" Padding="5">
                        <ItemsControl x:Name="AccountsListControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid x:Name="MsLogo" Width="14" Height="14" Margin="10,0,10,0" VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Fill="#F25022" Margin="0,0,1,1"/>
                                            <Rectangle Grid.Column="1" Fill="#7FBA00" Margin="1,0,0,1"/>
                                            <Rectangle Grid.Row="1" Fill="#00A4EF" Margin="0,1,1,0"/>
                                            <Rectangle Grid.Row="1" Grid.Column="1" Fill="#FFB900" Margin="1,1,0,0"/>
                                        </Grid>

                                        <TextBlock Grid.Column="1" Text="{Binding Nickname}" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" FontSize="14"/>
                                        <Button Grid.Column="2" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" Width="30" Height="30" Style="{StaticResource DarkButtonStyle}" Foreground="#E81123" Click="DeleteAccount_Click" Tag="{Binding Nickname}"/>
                                    </Grid>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding AccessToken}" Value="offline">
                                            <Setter TargetName="MsLogo" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <TextBlock Text="Оффлайн аккаунт (Пиратка)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OfflineNicknameBox" Style="{StaticResource CustomTextBoxStyle}" Height="45" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" Content="Добавить ник" Width="140" Height="45" Style="{StaticResource DarkButtonStyle}" Click="AddOfflineAccount_Click" FontSize="16"/>
                    </Grid>

                    <TextBlock Text="Лицензия (Для официальных серверов)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13" Margin="0,0,0,5"/>
                    <Button Content="Добавить аккаунт Microsoft" Width="250" Height="45" HorizontalAlignment="Left" Style="{StaticResource PlayButtonStyle}" Click="AddMicrosoftAccount_Click" Margin="0,0,0,25" FontSize="16"/>

                    <Border Height="1" Background="{DynamicResource HoverOverlayBrush}" Margin="0,0,0,20"/>

                    <TextBlock Text="ДАННЫЕ" Foreground="{DynamicResource AccentBrush}" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Экспорт" Width="120" Height="40" Style="{StaticResource DarkButtonStyle}" Margin="0,0,10,0" Click="ExportSettings_Click" FontSize="16"/>
                        <Button Content="Импорт" Width="120" Height="40" Style="{StaticResource DarkButtonStyle}" Margin="0,0,10,0" Click="ImportSettings_Click" FontSize="16"/>
                        <Button Content="Сбросить" Width="120" Height="40" Style="{StaticResource DarkButtonStyle}" Foreground="#E81123" Click="ResetSettings_Click" FontSize="16"/>
                    </StackPanel>

                    <Button Content="Сохранить настройки" Width="220" Height="50" HorizontalAlignment="Right" Margin="0,20,0,0" Style="{StaticResource PlayButtonStyle}" Background="#4CAF50" Click="SaveButton_Click" FontSize="16"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>